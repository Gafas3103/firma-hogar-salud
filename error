<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Error — Hogar Salud IPS SAS</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',Arial,sans-serif;background:#f1f5f9;min-height:100vh;display:flex;flex-direction:column}
.hdr{background:linear-gradient(135deg,#0f2d5a,#1e40af);padding:18px 24px;display:flex;align-items:center;gap:14px}
.hdr-logo{width:42px;height:42px;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:#fff;flex-shrink:0}
.hdr h1{color:#fff;font-size:17px;font-weight:700;margin-bottom:2px}
.hdr p{color:rgba(255,255,255,0.7);font-size:12px}
.main{flex:1;display:flex;align-items:center;justify-content:center;padding:32px 16px}
.box{background:#fff;border-radius:20px;border:1px solid #e2e8f0;box-shadow:0 8px 32px rgba(0,0,0,.08);max-width:520px;width:100%;overflow:hidden}
.box-top{background:linear-gradient(135deg,#fef2f2,#fee2e2);padding:40px 36px 32px;text-align:center;border-bottom:1px solid #fecaca}
.icon-wrap{width:80px;height:80px;border-radius:50%;background:#fff;border:3px solid #fca5a5;display:flex;align-items:center;justify-content:center;font-size:36px;margin:0 auto 20px}
.box-top h2{font-size:22px;font-weight:900;color:#991b1b;margin-bottom:8px}
.box-top p{font-size:14px;color:#b91c1c;line-height:1.6}
.box-body{padding:32px 36px}
.info-row{display:flex;align-items:flex-start;gap:12px;background:#fafafa;border:1px solid #e2e8f0;border-radius:12px;padding:14px 16px;margin-bottom:14px}
.info-icon{font-size:20px;flex-shrink:0;margin-top:1px}
.info-text{font-size:13px;color:#334155;line-height:1.6}
.info-text strong{color:#0f172a;font-weight:700;display:block;margin-bottom:3px}
.divider{text-align:center;font-size:12px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin:20px 0;position:relative}
.divider::before,.divider::after{content:'';position:absolute;top:50%;width:40%;height:1px;background:#e2e8f0}
.divider::before{left:0}.divider::after{right:0}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.contact-btn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:16px 10px;border-radius:12px;text-decoration:none;font-weight:700;font-size:13px;transition:all .2s;border:2px solid transparent}
.contact-btn.whatsapp{background:#f0fdf4;border-color:#86efac;color:#166534}
.contact-btn.whatsapp:hover{background:#dcfce7;border-color:#4ade80}
.contact-btn.email{background:#eff6ff;border-color:#93c5fd;color:#1e40af}
.contact-btn.email:hover{background:#dbeafe;border-color:#60a5fa}
.contact-btn .cb-icon{font-size:24px}
.contact-btn .cb-label{font-size:11px;color:inherit;opacity:.8}
.ref-box{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px 14px;text-align:center}
.ref-box p{font-size:12px;color:#64748b;margin-bottom:4px}
.ref-box code{font-size:11px;color:#475569;background:#e2e8f0;padding:2px 8px;border-radius:4px;font-family:monospace}
footer{text-align:center;padding:16px;font-size:11px;color:#94a3b8;line-height:1.6;border-top:1px solid #e2e8f0;background:#fff}
@media(max-width:480px){.box-top,.box-body{padding:24px 20px}.contact-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="hdr">
  <div class="hdr-logo">HS</div>
  <div>
    <h1>Hogar Salud IPS SAS</h1>
    <p>Sistema de Firma Digital</p>
  </div>
</div>

<div class="main">
  <div class="box">
    <div class="box-top">
      <div class="icon-wrap">⚠️</div>
      <h2>Enlace no valido</h2>
      <p>El enlace que recibiste no corresponde a ningun tipo de contrato registrado en nuestro sistema o puede haber expirado.</p>
    </div>
    <div class="box-body">

      <div class="info-row">
        <span class="info-icon">🔍</span>
        <div class="info-text">
          <strong>¿Que pudo haber pasado?</strong>
          El enlace esta incompleto, fue modificado, o el tipo de contrato no fue configurado correctamente por Recursos Humanos.
        </div>
      </div>

      <div class="info-row">
        <span class="info-icon">✅</span>
        <div class="info-text">
          <strong>¿Que debes hacer?</strong>
          Contacta a Recursos Humanos para que te envien un nuevo enlace de firma. No es necesario que hagas nada mas por ahora.
        </div>
      </div>

      <div class="divider">Contactar soporte</div>

      <div class="contact-grid">
        <a class="contact-btn whatsapp" href="https://wa.me/573XXXXXXXXX?text=Hola%2C%20el%20enlace%20de%20mi%20contrato%20no%20funciona.%20Referencia%3A%20" id="btnWA" target="_blank">
          <span class="cb-icon">💬</span>
          <span>WhatsApp</span>
          <span class="cb-label">Recursos Humanos</span>
        </a>
        <a class="contact-btn email" href="mailto:rrhh@hogarsaludips.com?subject=Enlace%20de%20contrato%20no%20valido&body=Hola%2C%20el%20enlace%20de%20mi%20contrato%20no%20funciona." id="btnEmail">
          <span class="cb-icon">✉️</span>
          <span>Correo</span>
          <span class="cb-label">rrhh@hogarsaludips.com</span>
        </a>
      </div>

      <div class="ref-box">
        <p>Referencia para soporte:</p>
        <code id="refCode">sin-token</code>
      </div>

    </div>
  </div>
</div>

<footer>
  Hogar Salud IPS SAS &bull; NIT 900.369.003-1 &bull; Carrera 56 # 72-129, Barranquilla<br>
  Si recibiste este enlace por error, puedes ignorarlo.
</footer>

<script>
/* Mostrar el token en la referencia para que soporte identifique el caso */
var P     = new URLSearchParams(location.search);
var token = P.get('token') || 'sin-token';
var tipo  = P.get('tipo')  || 'desconocido';
var nom   = P.get('nombre')|| '';

document.getElementById('refCode').textContent = token.substring(0, 8) + '...';

/* Agregar token al mensaje de WhatsApp para que soporte lo identifique */
var waBase = 'https://wa.me/573XXXXXXXXX?text=';
var waMsg  = 'Hola, el enlace de mi contrato no funciona.'
           + (nom ? ' Soy ' + nom + '.' : '')
           + ' Referencia: ' + token.substring(0, 8);
document.getElementById('btnWA').href = waBase + encodeURIComponent(waMsg);

/* Agregar info al correo */
var emailBody = 'Hola,\n\nEl enlace de mi contrato no funciona.\n'
              + (nom ? 'Nombre: ' + nom + '\n' : '')
              + 'Referencia: ' + token.substring(0, 8) + '\n'
              + 'Tipo recibido: ' + tipo + '\n\n'
              + 'Por favor enviarme un nuevo enlace.\n\nGracias.';
document.getElementById('btnEmail').href =
  'mailto:rrhh@hogarsaludips.com'
  + '?subject=' + encodeURIComponent('Enlace de contrato no valido')
  + '&body='    + encodeURIComponent(emailBody);
</script>
</body>
</html>
